# Firebase — copia este archivo a .env.local y rellena los valores.
# Obtén las credenciales en: Firebase Console → Project Settings → Your apps → Web app → SDK setup

# API Key (pública, va en el cliente)
VITE_FIREBASE_API_KEY=

# Auth domain (ej. mi-proyecto.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=

# Project ID
VITE_FIREBASE_PROJECT_ID=

# Storage bucket (ej. mi-proyecto.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=

# Messaging sender ID (número)
VITE_FIREBASE_MESSAGING_SENDER_ID=

# App ID (ej. 1:123456789:web:abc123)
VITE_FIREBASE_APP_ID=

# Pasos en Firebase Console (una sola vez):
# 1. Authentication → Sign-in method → Google → Habilitar
# 2. Authentication → Settings → Authorized domains → añadir localhost y tu dominio Vercel
# 3. En Vercel: Settings → Environment Variables → pegar las mismas 6 variables
